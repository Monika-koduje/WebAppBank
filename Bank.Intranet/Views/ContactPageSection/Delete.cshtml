@model Company.Data.Data.ContactPageSection

@{
    ViewData["Title"] = "Delete Contact Page Section";
}

<section class="table-section">
    <div class="container mt-5">
        <h1 class="text-danger">
            <i class="fas fa-exclamation-circle"></i> Delete Contact Page Section
        </h1>
        <p class="lead">Are you sure you want to delete this section? This action cannot be undone.</p>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">
                    <i class="fas fa-info-circle"></i> Section Details
                </h4>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <!-- Section Name -->
                    <dt class="col-sm-3 text-secondary">
                        <i class="fas fa-heading"></i> @Html.DisplayNameFor(model => model.SectionName)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.SectionName)
                    </dd>

                    <!-- Content -->
                    <dt class="col-sm-3 text-secondary">
                        <i class="fas fa-paragraph"></i> @Html.DisplayNameFor(model => model.Content)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.Content)
                    </dd>

                    <!-- Image URL -->
                    <dt class="col-sm-3 text-secondary">
                        <i class="fas fa-image"></i> @Html.DisplayNameFor(model => model.ImageUrl)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.ImageUrl)
                    </dd>

                    <!-- Icon Class -->
                    <dt class="col-sm-3 text-secondary">
                        <i class="fas fa-icons"></i> @Html.DisplayNameFor(model => model.IconClass)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.IconClass)
                    </dd>

                    <!-- Order -->
                    <dt class="col-sm-3 text-secondary">
                        <i class="fas fa-sort"></i> @Html.DisplayNameFor(model => model.Order)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.Order)
                    </dd>

                    <!-- Is Active -->
                    <dt class="col-sm-3 text-secondary">
                        <i class="fas fa-toggle-on"></i> @Html.DisplayNameFor(model => model.IsActive)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.IsActive)
                    </dd>
                </dl>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <!-- Delete Button -->
            <form asp-action="Delete" class="d-inline">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash-alt"></i> Delete
                </button>
            </form>

            <!-- Back to List -->
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
