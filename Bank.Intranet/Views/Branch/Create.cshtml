@model Company.Data.Data.Branch

@{
    ViewData["Title"] = "Create";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
        <h1 class="text-primary">
        <i class="fas fa-building"></i> Create Branch
    </h1>
    <p class="lead">Please fill in the details below to create a new branch.</p>

    <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-clipboard-list"></i> Add New Branch
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Branch Name -->
                <div class="form-group">
                    <label asp-for="BranchName" class="control-label">
                        <i class="fas fa-sign"></i> @Html.DisplayNameFor(model => model.BranchName)
                    </label>
                    <input asp-for="BranchName" class="form-control" />
                    <span asp-validation-for="BranchName" class="text-danger"></span>
                </div>

                <!-- Address -->
                <div class="form-group">
                    <label asp-for="Address" class="control-label">
                        <i class="fas fa-map-marker-alt"></i> @Html.DisplayNameFor(model => model.Address)
                    </label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <!-- City -->
                <div class="form-group">
                    <label asp-for="City" class="control-label">
                        <i class="fas fa-city"></i> @Html.DisplayNameFor(model => model.City)
                    </label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>

                <!-- Postal Code -->
                <div class="form-group">
                    <label asp-for="PostalCode" class="control-label">
                        <i class="fas fa-mail-bulk"></i> @Html.DisplayNameFor(model => model.PostalCode)
                    </label>
                    <input asp-for="PostalCode" class="form-control" />
                    <span asp-validation-for="PostalCode" class="text-danger"></span>
                </div>

                <!-- Phone -->
                <div class="form-group">
                    <label asp-for="Phone" class="control-label">
                        <i class="fas fa-phone-alt"></i> @Html.DisplayNameFor(model => model.Phone)
                    </label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Submit Button -->
                <div class="form-group">
                    <input type="submit" value="Create" class="btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <!-- Back to List Link -->
    <div class="mt-3">
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
