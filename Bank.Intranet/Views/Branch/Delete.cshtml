@model Company.Data.Data.Branch

@{
    ViewData["Title"] = "Delete";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-danger">
        <i class="fas fa-trash-alt"></i> Delete Branch
    </h1>
    <p class="lead">Are you sure you want to delete this branch? This action cannot be undone.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="fas fa-exclamation-triangle"></i> Branch Details
            </h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-building"></i> @Html.DisplayNameFor(model => model.BranchName)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.BranchName)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-map-marker-alt"></i> @Html.DisplayNameFor(model => model.Address)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Address)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-city"></i> @Html.DisplayNameFor(model => model.City)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.City)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-mail-bulk"></i> @Html.DisplayNameFor(model => model.PostalCode)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.PostalCode)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-phone"></i> @Html.DisplayNameFor(model => model.Phone)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Phone)
                </dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <form asp-action="Delete" class="d-inline">
            <input type="hidden" asp-for="IdBranch" />
            <button type="submit" class="btn-danger">
                <i class="fas fa-trash"></i> Delete
            </button>
        </form>
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
