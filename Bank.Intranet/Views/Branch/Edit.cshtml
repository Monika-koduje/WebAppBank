@model Company.Data.Data.Branch

@{
    ViewData["Title"] = "Edit Branch";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-edit"></i> Edit Branch
    </h1>
    <p class="lead">Update the branch details below.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">
                <i class="fas fa-building"></i> Branch Information
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Hidden Field for IdBranch -->
                <input type="hidden" asp-for="IdBranch" />

                <!-- Branch Name -->
                <div class="form-group">
                    <label asp-for="BranchName" class="control-label">
                        <i class="fas fa-building"></i> Branch Name
                    </label>
                    <input asp-for="BranchName" class="form-control" />
                    <span asp-validation-for="BranchName" class="text-danger"></span>
                </div>

                <!-- Address -->
                <div class="form-group">
                    <label asp-for="Address" class="control-label">
                        <i class="fas fa-map-marker-alt"></i> Address
                    </label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <!-- City -->
                <div class="form-group">
                    <label asp-for="City" class="control-label">
                        <i class="fas fa-city"></i> City
                    </label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>

                <!-- Postal Code -->
                <div class="form-group">
                    <label asp-for="PostalCode" class="control-label">
                        <i class="fas fa-postal-code"></i> Postal Code
                    </label>
                    <input asp-for="PostalCode" class="form-control" />
                    <span asp-validation-for="PostalCode" class="text-danger"></span>
                </div>

                <!-- Phone -->
                <div class="form-group">
                    <label asp-for="Phone" class="control-label">
                        <i class="fas fa-phone-alt"></i> Phone
                    </label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Submit Button -->
                    <div class="form-group">
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
