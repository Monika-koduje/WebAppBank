@model Company.Data.Data.Card

@{
    ViewData["Title"] = "Create";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-credit-card"></i> Create Card
    </h1>
    <p class="lead">Fill out the form to create a new card.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-plus-circle"></i> Add New Card
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Card Number -->
                <div class="form-group">
                    <label asp-for="CardNumber" class="control-label">
                        <i class="fas fa-credit-card"></i> @Html.DisplayNameFor(model => model.CardNumber)
                    </label>
                    <input asp-for="CardNumber" class="form-control" />
                    <span asp-validation-for="CardNumber" class="text-danger"></span>
                </div>

                <!-- Expiry Date -->
                <div class="form-group">
                    <label asp-for="ExpiryDate" class="control-label">
                        <i class="fas fa-calendar-day"></i> @Html.DisplayNameFor(model => model.ExpiryDate)
                    </label>
                    <input asp-for="ExpiryDate" class="form-control" />
                    <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                </div>

                <!-- Card Type -->
                <div class="form-group">
                    <label asp-for="CardTypeId" class="control-label">
                        <i class="fas fa-credit-card-alt"></i> @Html.DisplayNameFor(model => model.CardTypeId)
                    </label>
                    <select asp-for="CardTypeId" class="form-control" asp-items="ViewBag.CardTypeId"></select>
                    <span asp-validation-for="CardTypeId" class="text-danger"></span>
                </div>

                <!-- Card Holder -->
                <div class="form-group">
                    <label asp-for="CardHolder" class="control-label">
                        <i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.CardHolder)
                    </label>
                    <input asp-for="CardHolder" class="form-control" />
                    <span asp-validation-for="CardHolder" class="text-danger"></span>
                </div>

                <!-- CVV -->
                <div class="form-group">
                    <label asp-for="CVV" class="control-label">
                        <i class="fas fa-lock"></i> @Html.DisplayNameFor(model => model.CVV)
                    </label>
                    <input asp-for="CVV" class="form-control" />
                    <span asp-validation-for="CVV" class="text-danger"></span>
                </div>

                <!-- Submit Button -->
                <div class="form-group">
                    <input type="submit" value="Create" class="btn-success" />
                </div>
            </form>
        </div>
    </div>

    <!-- Back to List Link -->
    <div class="mt-3">
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
