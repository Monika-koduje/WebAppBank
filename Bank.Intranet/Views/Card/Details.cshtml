@model Company.Data.Data.Card

@{
    ViewData["Title"] = "Card Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-credit-card"></i> Card Details
    </h1>
    <p class="lead">View the details of the selected card below.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-id-card"></i> Card Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <!-- Card Number -->
                <dt class="col-sm-2">
                    <i class="fas fa-credit-card"></i> @Html.DisplayNameFor(model => model.CardNumber)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.CardNumber)
                </dd>

                <!-- Expiry Date -->
                <dt class="col-sm-2">
                    <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.ExpiryDate)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.ExpiryDate)
                </dd>

                <!-- Card Type -->
                <dt class="col-sm-2">
                    <i class="fas fa-credit-card"></i> @Html.DisplayNameFor(model => model.CardType)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.CardType.Name)
                </dd>

                <!-- Card Holder -->
                <dt class="col-sm-2">
                    <i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.CardHolder)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.CardHolder)
                </dd>

                <!-- CVV -->
                <dt class="col-sm-2">
                    <i class="fas fa-lock"></i> @Html.DisplayNameFor(model => model.CVV)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.CVV)
                </dd>
            </dl>
        </div>
    </div>

        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdCard" class="btn-warning">
            <i class="fas fa-edit"></i> Edit Card
        </a> 
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
