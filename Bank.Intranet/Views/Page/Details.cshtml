@model Company.Data.Data.CMS.Page

@{
    ViewData["Title"] = "Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-info-circle"></i> Page Details
    </h1>
    <p class="lead">Here are the details of the selected page.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-file-alt"></i> Page Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <!-- Link Title -->
                <dt class="col-sm-2">
                    <i class="fas fa-link"></i> @Html.DisplayNameFor(model => model.LinkTitle)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.LinkTitle)
                </dd>

                <!-- Title -->
                <dt class="col-sm-2">
                    <i class="fas fa-heading"></i> @Html.DisplayNameFor(model => model.Title)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Title)
                </dd>

                <!-- Content -->
                <dt class="col-sm-2">
                    <i class="fas fa-file-alt"></i> @Html.DisplayNameFor(model => model.Content)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Content)
                </dd>

                <!-- Display Order -->
                <dt class="col-sm-2">
                    <i class="fas fa-sort-amount-down"></i> @Html.DisplayNameFor(model => model.DisplayOrder)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.DisplayOrder)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Action Links -->
        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdPage" class="btn-warning">
            <i class="fas fa-edit"></i> Edit Page
        </a> 
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
