@model Company.Data.Data.CMS.Page

@{
    ViewData["Title"] = "Edit";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-edit"></i> Edit Page
    </h1>
    <p class="lead">You can edit the details of the selected page here.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">
                <i class="fas fa-pencil-alt"></i> Edit Page Details
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="IdPage" />

                <!-- Link Title -->
                <div class="form-group">
                    <label asp-for="LinkTitle" class="control-label">
                        <i class="fas fa-link"></i> @Html.DisplayNameFor(model => model.LinkTitle)
                    </label>
                    <input asp-for="LinkTitle" class="form-control" />
                    <span asp-validation-for="LinkTitle" class="text-danger"></span>
                </div>

                <!-- Title -->
                <div class="form-group">
                    <label asp-for="Title" class="control-label">
                        <i class="fas fa-heading"></i> @Html.DisplayNameFor(model => model.Title)
                    </label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- Content -->
                <div class="form-group">
                    <label asp-for="Content" class="control-label">
                        <i class="fas fa-file-alt"></i> @Html.DisplayNameFor(model => model.Content)
                    </label>
                    <input asp-for="Content" class="form-control" />
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <!-- Display Order -->
                <div class="form-group">
                    <label asp-for="DisplayOrder" class="control-label">
                        <i class="fas fa-sort-amount-down"></i> @Html.DisplayNameFor(model => model.DisplayOrder)
                    </label>
                    <input asp-for="DisplayOrder" class="form-control" />
                    <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                </div>

                <!-- Save Button -->
                    <div class="form-group">
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
            </form>
        </div>
    </div>

    <!-- Back to List Link -->
    <div class="mt-3">
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
