@model Company.Data.Data.Client

@{
    ViewData["Title"] = "Edit Client";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-user-edit"></i> Edit Client
    </h1>
    <p class="lead">Edit the details of the selected client.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">
                <i class="fas fa-edit"></i> Edit Client Information
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="IdClient" />

                <!-- First Name -->
                <div class="form-group">
                    <label asp-for="FirstName" class="control-label">
                        <i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.FirstName)
                    </label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <!-- Last Name -->
                <div class="form-group">
                    <label asp-for="LastName" class="control-label">
                        <i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.LastName)
                    </label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="form-group">
                    <label asp-for="Email" class="control-label">
                        <i class="fas fa-envelope"></i> @Html.DisplayNameFor(model => model.Email)
                    </label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Phone -->
                <div class="form-group">
                    <label asp-for="Phone" class="control-label">
                        <i class="fas fa-phone-alt"></i> @Html.DisplayNameFor(model => model.Phone)
                    </label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <!-- Created At -->
                <div class="form-group">
                    <label asp-for="CreatedAt" class="control-label">
                        <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.CreatedAt)
                    </label>
                    <input asp-for="CreatedAt" class="form-control" />
                    <span asp-validation-for="CreatedAt" class="text-danger"></span>
                </div>

                <!-- Submit Button -->
                    <div class="form-group">
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
            </form>
        </div>
    </div>
 

    <!-- Action Buttons -->
    <div class="mt-3">
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
