@model Company.Data.Data.Employee

@{
    ViewData["Title"] = "Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-user"></i> Employee Details
    </h1>
    <p class="lead">Here are the details of the selected employee.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-info-circle"></i> Employee Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <!-- First Name -->
                <dt class="col-sm-2">
                    <i class="fas fa-user-tag"></i> @Html.DisplayNameFor(model => model.FirstName)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.FirstName)
                </dd>

                <!-- Last Name -->
                <dt class="col-sm-2">
                    <i class="fas fa-user-tag"></i> @Html.DisplayNameFor(model => model.LastName)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.LastName)
                </dd>

                <!-- Position -->
                <dt class="col-sm-2">
                    <i class="fas fa-briefcase"></i> @Html.DisplayNameFor(model => model.Position)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Position)
                </dd>

                <!-- Hire Date -->
                <dt class="col-sm-2">
                    <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.HireDate)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.HireDate)
                </dd>

                <!-- Phone -->
                <dt class="col-sm-2">
                    <i class="fas fa-phone-alt"></i> @Html.DisplayNameFor(model => model.Phone)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Phone)
                </dd>

                <!-- Branch Address -->
                <dt class="col-sm-2">
                    <i class="fas fa-building"></i> @Html.DisplayNameFor(model => model.Branch)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Branch.Address)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Action Buttons -->
        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdEmployee" class="btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a>
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
