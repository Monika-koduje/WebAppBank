@model Company.Data.Data.BankProduct

@{
    ViewData["Title"] = "Edit Bank Product";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-pencil-alt"></i> Edit Bank Product
    </h1>
    <p class="lead">Modify the details of the bank product below.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">
                <i class="fas fa-edit"></i> Edit Product Details
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="IdProduct" />

                <!-- Product Name -->
                <div class="form-group">
                    <label asp-for="ProductName" class="control-label">
                        <i class="fas fa-tag"></i> @Html.DisplayNameFor(model => model.ProductName)
                    </label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label asp-for="Description" class="control-label">
                        <i class="fas fa-align-left"></i> @Html.DisplayNameFor(model => model.Description)
                    </label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Product Type -->
                <div class="form-group">
                    <label asp-for="ProductType" class="control-label">
                        <i class="fas fa-sitemap"></i> @Html.DisplayNameFor(model => model.ProductType)
                    </label>
                    <input asp-for="ProductType" class="form-control" />
                    <span asp-validation-for="ProductType" class="text-danger"></span>
                </div>

                <!-- Interest Rate -->
                <div class="form-group">
                    <label asp-for="InterestRate" class="control-label">
                        <i class="fas fa-percent"></i> @Html.DisplayNameFor(model => model.InterestRate)
                    </label>
                    <input asp-for="InterestRate" class="form-control" />
                    <span asp-validation-for="InterestRate" class="text-danger"></span>
                </div>

                <!-- Submit Button -->
                    <div class="form-group">
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
            </form>
        </div>
    </div>

    <div>
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
