@model Company.Data.Data.BankProduct

@{
    ViewData["Title"] = "Details of Bank Product";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-cogs"></i> Bank Product Details
    </h1>
    <p class="lead">View the details of the selected bank product.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-info-circle"></i> Bank Product Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-2">
                    <i class="fas fa-tag"></i> @Html.DisplayNameFor(model => model.ProductName)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.ProductName)
                </dd>

                <dt class="col-sm-2">
                    <i class="fas fa-align-left"></i> @Html.DisplayNameFor(model => model.Description)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Description)
                </dd>

                <dt class="col-sm-2">
                    <i class="fas fa-sitemap"></i> @Html.DisplayNameFor(model => model.ProductType)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.ProductType)
                </dd>

                <dt class="col-sm-2">
                    <i class="fas fa-percent"></i> @Html.DisplayNameFor(model => model.InterestRate)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.InterestRate)
                </dd>
            </dl>
        </div>
    </div>

        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdProduct" class="btn-warning">
            <i class="fas fa-pencil-alt"></i> Edit Product
        </a> 
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
