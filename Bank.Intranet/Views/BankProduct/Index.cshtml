@model IEnumerable<Company.Data.Data.BankProduct>

@{
    ViewData["Title"] = "Index";
}
<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section"> 

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="m-0">Products</h1>
    <p class="mb-0">
        <!-- Wyśrodkowany przycisk -->
        <a class="btn btn-primary" asp-action="Create">
            <i class="fas fa-plus-circle"></i>
        </a>
    </p>
</div>

    <!-- Tabela -->
    <table class="table table-bordered table-striped table-hover">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.ProductName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Description)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.ProductType)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.InterestRate)
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.ProductName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ProductType)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.InterestRate)
                    </td>
                    <td class="text-center">
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.IdProduct">
                            <i class="fas fa-edit"></i> 
                        </a>
                        <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.IdProduct">
                            <i class="fas fa-eye"></i> 
                        </a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.IdProduct" onclick="return confirm('Are you sure you want to delete this product?');">
                            <i class="fas fa-trash-alt"></i> 
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="image">
    <img src="~/img/img10.png" />
</section>


<section class="icons-section">
    <!-- Home Page -->
    <a class="icon-link" asp-area="" asp-controller="Home" asp-action="Index" title="Home Page">
        <i class="fas fa-home"></i>
    </a>
    <a class="icon-link" asp-area="" asp-controller="ClientBankProduct" asp-action="Index" title="Customer Products">
        <i class="fas fa-tools"></i>
    </a>
</section>