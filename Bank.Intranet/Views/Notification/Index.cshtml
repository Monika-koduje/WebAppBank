@model IEnumerable<Company.Data.Data.Notification>

@{
    ViewData["Title"] = "Index";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="m-0">Notifications</h1>
        <p class="mb-0">
            <!-- Wyśrodkowany przycisk -->
            <a class="btn btn-primary" asp-action="Create">
                <i class="fas fa-plus-circle"></i>
            </a>
        </p>
    </div>

    <!-- Tabela -->
    <table class="table table-bordered table-striped table-hover">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Title)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Message)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.NotificationDate)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Client)
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Message)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.NotificationDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Client.Email)
                    </td>
                    <td class="text-center">
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.IdNotification">
                            <i class="fas fa-edit"></i> 
                        </a>
                        <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.IdNotification">
                            <i class="fas fa-eye"></i> 
                        </a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.IdNotification" onclick="return confirm('Are you sure you want to delete this notification?');">
                            <i class="fas fa-trash-alt"></i> 
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="image">
    <img src="~/img/img14.jpg" />
</section>


<section class="icons-section">
    <!-- Home Page -->
    <a class="icon-link" asp-area="" asp-controller="Home" asp-action="Index" title="Home Page">
        <i class="fas fa-home"></i>
    </a>
    </a>
    <a class="icon-link" asp-area="" asp-controller="Branch" asp-action="Index" title="Branches">
        <i class="fas fa-building"></i>
    </a>
    <a class="icon-link" asp-area="" asp-controller="Employee" asp-action="Index" title="Employees">
        <i class="fas fa-user-tie"></i>
    </a>
</section>
