@model Company.Data.Data.Notification

@{
    ViewData["Title"] = "Edit";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-edit"></i> Edit Notification
    </h1>
    <p class="lead">Edit the details of the selected notification below.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">
                <i class="fas fa-pencil-alt"></i> Edit Notification Information
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Hidden Id -->
                <input type="hidden" asp-for="IdNotification" />

                <!-- Title -->
                <div class="form-group">
                    <label asp-for="Title" class="control-label">
                        <i class="fas fa-heading"></i> @Html.DisplayNameFor(model => model.Title)
                    </label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- Message -->
                <div class="form-group">
                    <label asp-for="Message" class="control-label">
                        <i class="fas fa-comment-dots"></i> @Html.DisplayNameFor(model => model.Message)
                    </label>
                    <input asp-for="Message" class="form-control" />
                    <span asp-validation-for="Message" class="text-danger"></span>
                </div>

                <!-- Notification Date -->
                <div class="form-group">
                    <label asp-for="NotificationDate" class="control-label">
                        <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.NotificationDate)
                    </label>
                    <input asp-for="NotificationDate" class="form-control" />
                    <span asp-validation-for="NotificationDate" class="text-danger"></span>
                </div>

                <!-- Client -->
                <div class="form-group">
                    <label asp-for="IdClient" class="control-label">
                        <i class="fas fa-envelope"></i> @Html.DisplayNameFor(model => model.Client)
                    </label>
                    <select asp-for="IdClient" class="form-control" asp-items="ViewBag.IdClient"></select>
                    <span asp-validation-for="IdClient" class="text-danger"></span>
                </div>

                <!-- Save Button -->
                    <div class="form-group">
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
            </form>
        </div>
    </div>

    <!-- Action Links -->
    <div class="mt-3">
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
