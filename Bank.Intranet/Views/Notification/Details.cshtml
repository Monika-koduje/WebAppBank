@model Company.Data.Data.Notification

@{
    ViewData["Title"] = "Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-bell"></i> Notification Details
    </h1>
    <p class="lead">View the details of the selected notification.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-info-circle"></i> Notification Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <!-- Title -->
                <dt class="col-sm-2">
                    <i class="fas fa-heading"></i> @Html.DisplayNameFor(model => model.Title)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Title)
                </dd>

                <!-- Message -->
                <dt class="col-sm-2">
                    <i class="fas fa-comment-dots"></i> @Html.DisplayNameFor(model => model.Message)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Message)
                </dd>

                <!-- Notification Date -->
                <dt class="col-sm-2">
                    <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.NotificationDate)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.NotificationDate)
                </dd>

                <!-- Client Email -->
                <dt class="col-sm-2">
                    <i class="fas fa-envelope"></i> @Html.DisplayNameFor(model => model.Client)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Client.Email)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Action Links -->
        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdNotification" class="btn-warning">
            <i class="fas fa-pencil-alt"></i> Edit
        </a> 
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
