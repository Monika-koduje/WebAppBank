@model Company.Data.Data.Account

@{
    ViewData["Title"] = "Account Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-user-circle"></i> Account Details
    </h1>
    <p class="lead">Here are the details of account.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-info-circle"></i> Account Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-credit-card"></i> @Html.DisplayNameFor(model => model.AccountNumber)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.AccountNumber)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-dollar-sign"></i> @Html.DisplayNameFor(model => model.Balance)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Balance)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.Client)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Client.Email)
                </dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdAccount" class="btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a>
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
