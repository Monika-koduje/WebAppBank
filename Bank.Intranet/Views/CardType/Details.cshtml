@model Company.Data.Data.CardType

@{
    ViewData["Title"] = "Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-credit-card"></i> Card Type Details
    </h1>
    <p class="lead">View the details of the selected card type.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-info-circle"></i> Card Type Information
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <!-- Card Name -->
                <dt class="col-sm-2">
                    <i class="fas fa-tag"></i> @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <!-- Card Description -->
                <dt class="col-sm-2">
                    <i class="fas fa-info-circle"></i> @Html.DisplayNameFor(model => model.Description)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Description)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Navigation Links -->
        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdCardType" class="btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a> 
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
