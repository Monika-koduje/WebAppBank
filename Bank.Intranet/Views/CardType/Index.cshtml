@model IEnumerable<Company.Data.Data.CardType>

@{
    ViewData["Title"] = "Index";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="m-0">Type of Cards</h1>
        <p class="mb-0">
            <!-- Wyśrodkowany przycisk -->
            <a class="btn btn-primary" asp-action="Create">
                <i class="fas fa-plus-circle"></i>
            </a>
        </p>
    </div>
    <!-- Tabela -->
    <table class="table table-bordered table-striped table-hover">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Description)
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td class="text-center">
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.IdCardType">
                            <i class="fas fa-edit"></i> 
                        </a>
                        <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.IdCardType">
                            <i class="fas fa-eye"></i> 
                        </a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.IdCardType" onclick="return confirm('Are you sure you want to delete this card type?');">
                            <i class="fas fa-trash-alt"></i> 
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="image">
    <img src="~/img/img9.png" />
</section>


<section class="icons-section">
    <!-- Home Page -->
    <a class="icon-link" asp-area="" asp-controller="Home" asp-action="Index" title="Home Page">
        <i class="fas fa-home"></i>
    </a>
    <a class="icon-link" asp-area="" asp-controller="Card" asp-action="Index" title="Cards">
        <i class="fas fa-credit-card"></i>
    </a>
</section>
