@model IEnumerable<Company.Data.Data.Transaction>

@{
    ViewData["Title"] = "Index";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="m-0">Transactions</h1>
        <p class="mb-0">
            <!-- Wyśrodkowany przycisk -->
            <a class="btn btn-primary" asp-action="Create">
                <i class="fas fa-plus-circle"></i>
            </a>
        </p>
    </div>
        <!-- Tabela -->
        <table class="table table-bordered table-striped table-hover">
            <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Account)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Amount)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.TransactionDate)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Description)
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="transition-row">
                    <td>
                        @Html.DisplayFor(modelItem => item.Account.AccountNumber)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Amount)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.TransactionDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td class="text-center">
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.IdTransaction">
                            <i class="fas fa-edit"></i> 
                        </a>
                        <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.IdTransaction">
                            <i class="fas fa-eye"></i> 
                        </a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.IdTransaction" onclick="return confirm('Are you sure you want to delete this transaction?');">
                            <i class="fas fa-trash-alt"></i> 
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="image">
    <img src="~/img/img7.jpg" />
</section>


<section class="icons-section">

    <!-- Accounts -->
    <a class="icon-link" asp-area="" asp-controller="Home" asp-action="Index" title="Home Page">
        <i class="fas fa-home"></i>
    </a>
    <a class="icon-link" asp-area="" asp-controller="Account" asp-action="Index" title="Accounts">
        <i class="fas fa-university"></i>
    </a>
    <a class="icon-link" asp-area="" asp-controller="Client" asp-action="Index" title="Clients">
        <i class="fas fa-user"></i>
    </a>

</section>