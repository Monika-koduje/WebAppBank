@model Company.Data.Data.ClientBankProduct

@{
    ViewData["Title"] = "Details";
}

<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">

<div class="container mt-5">
    <h1 class="text-primary">
        <i class="fas fa-info-circle"></i> Client Bank Product Details
    </h1>
    <p class="lead">Detailed information about the client and their associated bank product.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">
                <i class="fas fa-user-plus"></i> Client Bank Product Details
            </h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <!-- Client Email -->
                <dt class="col-sm-2">
                    <i class="fas fa-envelope"></i> @Html.DisplayNameFor(model => model.Client)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Client.Email)
                </dd>

                <!-- Bank Product Name -->
                <dt class="col-sm-2">
                    <i class="fas fa-credit-card"></i> @Html.DisplayNameFor(model => model.BankProduct)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.BankProduct.ProductName)
                </dd>

                <!-- Acquired Date -->
                <dt class="col-sm-2">
                    <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.AcquiredDate)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.AcquiredDate)
                </dd>
            </dl>
        </div>
    </div>

    <!-- Action Buttons -->
        <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Edit" asp-route-id="@Model?.IdClientProduct" class="btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a> 
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

</section>

<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
