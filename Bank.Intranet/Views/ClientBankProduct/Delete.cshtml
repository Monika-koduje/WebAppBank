@model Company.Data.Data.ClientBankProduct

@{
    ViewData["Title"] = "Delete";
}
<!-- Sekcja z tabelą z ograniczoną szerokością -->
<section class="table-section">
<div class="container mt-5">
    <h1 class="text-danger">
        <i class="fas fa-box-open"></i> Delete Client Bank Product
    </h1>
    <p class="lead">Are you sure you want to delete this client bank product? This action cannot be undone.</p>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">
                <i class="fas fa-exclamation-triangle"></i> Client Bank Product Details
            </h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.Client)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Client.Email)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-box"></i> @Html.DisplayNameFor(model => model.BankProduct)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.BankProduct.ProductName)
                </dd>
                <dt class="col-sm-3 text-secondary">
                    <i class="fas fa-calendar-alt"></i> @Html.DisplayNameFor(model => model.AcquiredDate)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.AcquiredDate)
                </dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <form asp-action="Delete" class="d-inline">
            <input type="hidden" asp-for="IdClientProduct" />
            <button type="submit" class="btn-danger">
                <i class="fas fa-trash"></i> Delete
            </button>
        </form>
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
</section>
<!-- Font Awesome CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
