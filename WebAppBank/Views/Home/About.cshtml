@model IEnumerable<Company.Data.Data.AboutPageSection>

@{
    ViewData["Title"] = "O nas";
}



<div class="container">
    <!-- Nagłówek sekcji -->
    <br><br>
    <h1 id="About" class="header center indigo-text text-darken-3">@ViewData["Title"]</h1>
    <br><br>

    <!-- Sekcje treści -->
    <div class="section">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <!-- Dynamiczna sekcja -->
                <div class="card-panel indigo lighten-5">
                    <h5 class="indigo-text text-darken-3">
                        <i class="@item.IconClass left"></i><b>@item.SectionName</b>
                    </h5>
                    <p class="grey-text text-darken-2">@Html.Raw(item.Content)</p>

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="responsive-img" />
                    }

                    <!-- Link do szczegółów sekcji -->
                    <p>
                        <a href="@Url.Action("Detail", "AboutPage", new { id = item.Id })" class="btn indigo">Zobacz szczegóły</a>
                    </p>
                </div>
            }
        }
        else
        {
            <div class="card-panel indigo lighten-5">
                <h5 class="indigo-text text-darken-3">Brak dostępnych informacji.</h5>
                <p class="grey-text text-darken-2">Przepraszamy, brak danych do wyświetlenia.</p>
            </div>
        }
    </div>
</div>

<!-- Font Awesome Icons -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
